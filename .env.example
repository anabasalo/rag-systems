# ===== rag-systems environment variables =====
# Copy this file to `.env` and fill in real values.
#
#   cp .env.example .env

# Groq API key (used in Phase 2+ for LLM generation).
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# LLM model name on Groq.
LLM_MODEL=llama3-8b-8192

# Sentence-transformers model name for embeddings.
EMBED_MODEL=all-MiniLM-L6-v2

# Where ChromaDB persists its files.
CHROMA_PERSIST_DIR=./data/chroma

# Default top-K for retrieval.
TOP_K=5

# Similarity floor below which retrieval is treated as "no result".
SIMILARITY_FLOOR=0.2

# Chunking parameters (chars, used as a ~token proxy).
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Path to the structured query log (Phase 5).
QUERY_LOG_PATH=./logs/queries.jsonl
